{
  "xsappname": "sap-cap-bookshop",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.admin",
      "description": "Admin access"
    },
    {
      "name": "$XSAPPNAME.viewer",
      "description": "Viewer access"
    }
  ],
  "role-templates": [
    {
      "name": "admin",
      "description": "Admin role",
      "scope-references": [
        "$XSAPPNAME.admin"
      ]
    },
    {
      "name": "viewer",
      "description": "Viewer role",
      "scope-references": [
        "$XSAPPNAME.viewer"
      ]
    }
  ],
  "role-collections": [
    {
      "name": "BookshopAdmin",
      "description": "Full access to bookshop",
      "role-template-references": [
        "$XSAPPNAME.admin"
      ]
    },
    {
      "name": "BookshopViewer",
      "description": "Read-only access to bookshop",
      "role-template-references": [
        "$XSAPPNAME.viewer"
      ]
    }
  ],
  "attributes": []
}
