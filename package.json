{
  "name": "my-cap-app",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/sqlite": "^2",
    "@sap/eslint-plugin-cds": "^4",
    "cds-plugin-ui5": "^0.17.0",
    "eslint": "^9",
    "jest": "^30.4.2"
  },
  "scripts": {
    "start": "cds-serve",
    "test": "jest --forceExit",
    "watch-bookshop-ui": "cds watch --open bookshopui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/bookshop-ui"
  ],
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "alice": {
            "password": "alice",
            "roles": [
              "admin"
            ]
          },
          "bob": {
            "password": "bob",
            "roles": [
              "viewer"
            ]
          },
          "eve": {
            "password": "eve",
            "roles": []
          }
        },
        "default": "alice"
      }
    }
  }
}
